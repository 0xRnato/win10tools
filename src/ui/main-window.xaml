<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="win10tools"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1b1b1f"
        Foreground="#e1e1e6"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark"   Color="#1b1b1f"/>
        <SolidColorBrush x:Key="BgMedium" Color="#252528"/>
        <SolidColorBrush x:Key="BgLight"  Color="#2e2e33"/>
        <SolidColorBrush x:Key="Border"   Color="#3a3a40"/>
        <SolidColorBrush x:Key="Accent"   Color="#5a9cff"/>
        <SolidColorBrush x:Key="Text"     Color="#e1e1e6"/>
        <SolidColorBrush x:Key="TextDim"  Color="#a0a0a6"/>
        <SolidColorBrush x:Key="Safe"     Color="#7bd88f"/>
        <SolidColorBrush x:Key="Minor"    Color="#e6d97e"/>
        <SolidColorBrush x:Key="Avoid"    Color="#ff7b80"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource BgMedium}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgDark}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="RowBackground" Value="{StaticResource BgDark}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgMedium}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgLight}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="RiskText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Safe}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Risk}" Value="Minor">
                    <Setter Property="Foreground" Value="{StaticResource Minor}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Risk}" Value="Avoid">
                    <Setter Property="Foreground" Value="{StaticResource Avoid}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgMedium}" Padding="12" Margin="0,0,0,8" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="win10tools" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Name="SubtitleText" Text="Tick what you want; Dry Run shows the preview; Run executes." Foreground="{StaticResource TextDim}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Name="AdminBadge" Text="non-admin" Foreground="{StaticResource Minor}" Margin="0,0,14,0" FontWeight="SemiBold"/>
                    <TextBlock Name="SessionBadge" Text="session --" Foreground="{StaticResource TextDim}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Name="CategoryTabs"
                    Grid.Row="1"
                    Background="{StaticResource BgDark}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"/>

        <Border Grid.Row="2" Background="{StaticResource BgMedium}" Padding="10" Margin="0,8,0,8" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="Deletion:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox Name="DeletionModeCombo" Width="140">
                        <ComboBoxItem Content="Recycle Bin" IsSelected="True"/>
                        <ComboBoxItem Content="Direct delete"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="Stale threshold:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider Name="ThresholdSlider"
                            Minimum="30" Maximum="365"
                            Value="90"
                            TickFrequency="30"
                            IsSnapToTickEnabled="True"
                            Width="180"
                            VerticalAlignment="Center"/>
                    <TextBlock Name="ThresholdLabel" Text="90 days" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Name="SelectionCountLabel"
                           Text="0 selected"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextDim}"
                           Margin="14,0,0,0"/>

                <TextBlock Grid.Column="3" Name="AvoidCountLabel"
                           Text=""
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Avoid}"
                           FontWeight="SemiBold"
                           Margin="14,0,0,0"/>

                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="DryRunButton" Content="Dry Run" Width="110"/>
                    <Button Name="RunButton" Content="Run" Width="110" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Button Name="ClearSelectionButton" Content="Clear" Width="72"/>
                    <Button Name="HelpButton" Content="Help" Width="60"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource BgMedium}" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Output" FontWeight="SemiBold" Margin="10,8,10,4"/>
                <TextBox Name="OutputBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         Background="#0e0e10"
                         Foreground="#d4d4d4"
                         BorderBrush="{StaticResource Border}"
                         BorderThickness="0,1,0,0"
                         Margin="10,0,10,10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
